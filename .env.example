# ============================================
# HyDash - Environment Configuration
# ============================================

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://hydash:hydash@localhost:5432/hydash
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hydash
DB_USER=hydash
DB_PASSWORD=hydash

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# CurseForge API
CURSEFORGE_API_KEY=

# Paths
BACKUP_DIR=/var/hydash/backups
SERVER_DATA_DIR=/var/hydash/servers

# Retention
LOG_RETENTION_DAYS=30
METRICS_RETENTION_DAYS=90
DEFAULT_BACKUP_RETENTION_DAYS=14

# Server Defaults
MAX_SERVERS_PER_USER=5
DEFAULT_MEMORY_LIMIT_MB=6144
DEFAULT_VIEW_DISTANCE=12

# Hytale Downloader
HYTALE_DOWNLOADER_PATH=/usr/local/bin/hytale-downloader