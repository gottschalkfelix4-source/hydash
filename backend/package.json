    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.22.4",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "dockerode": "^4.0.2",
    "ws": "^8.16.0",
    "axios": "^1.6.5",
    "multer": "^1.4.5-lts.1",
    "adm-zip": "^0.5.10",
    "tar": "^7.0.1",
    "node-cron": "^3.0.3",
