    "@types/pg": "^8.10.9",
    "@types/dockerode": "^3.3.23",
    "@types/ws": "^8.5.10",
    "@types/multer": "^1.4.11",
    "@types/adm-zip": "^0.5.5",
    "@types/tar": "^6.1.11",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1"
